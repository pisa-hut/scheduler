# Manager API URL
MANAGER_URL=http://pisa.hcislab.org/manager

# Path to the executor project directory (where uv run works)
# Defaults to ./executor (the submodule)
# EXECUTOR_DIR=./executor

# Poll interval in seconds
POLL_INTERVAL=10

# SLURM settings
SLURM_PARTITION=
SLURM_TIME=01:00:00
SLURM_CPUS=12
SLURM_MEM=12G

# Executor backend (apptainer or docker)
EXECUTOR_BACKEND=apptainer

# Optional: filter tasks by AV, simulator, map, sampler name
# FILTER_AV=autoware
# FILTER_SIMULATOR=esmini
# FILTER_MAP=
# FILTER_SAMPLER=

# Max concurrent SLURM jobs (0 = unlimited)
MAX_CONCURRENT_JOBS=0
